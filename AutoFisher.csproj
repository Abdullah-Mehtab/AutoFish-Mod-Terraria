<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <AssemblyName>AutoFisher</AssemblyName>
    <RootNamespace>AutoFisher</RootNamespace>
    <OutputType>Library</OutputType>
    <LangVersion>latest</LangVersion>
    <OutputPath>bin\Release\</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>
    <!-- Set this to your Terraria install folder before building -->
    <TerrariaPath>C:\Program Files (x86)\Steam\steamapps\common\Terraria</TerrariaPath>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="TerrariaModder.Core">
      <HintPath>$(TerrariaPath)\TerrariaModder\core\TerrariaModder.Core.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="0Harmony">
      <HintPath>$(TerrariaPath)\TerrariaModder\core\deps\0Harmony.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Terraria">
      <HintPath>$(TerrariaPath)\Terraria.exe</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>
</Project>
